# The Blue Alliance API Key
# Get your API key from: https://www.thebluealliance.com/account
# This is only needed for local development. In production, this is injected via GitHub secrets.
VITE_TBA_API_KEY=your_tba_api_key_here

# Google Sheets Integration
# Get your API key from: https://console.cloud.google.com/
# The Sheet ID is the long string in your Google Sheet URL (between /d/ and /edit)
VITE_GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key_here
VITE_GOOGLE_SHEETS_ID=your_google_sheets_id_here
