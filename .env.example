# The Blue Alliance API Key
# Get your API key from: https://www.thebluealliance.com/account
# This is only needed for local development. In production, this is injected via GitHub secrets.
VITE_TBA_API_KEY=your_tba_api_key_here

# Google Sheets integration via Google Apps Script
VITE_GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/your_apps_script_deployment_id/exec
